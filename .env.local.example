# ───────────────────────────────────────────────
# Supabase
# ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (scraper / admin tasks — NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ───────────────────────────────────────────────
# AI (restaurant data extraction / enrichment)
# ───────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ───────────────────────────────────────────────
# Maps
# ───────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your-kakao-map-key

# ───────────────────────────────────────────────
# Admin panel password (protects /admin and /api/admin/*)
# If left unset, the admin panel stays OPEN. Set this in production.
# ───────────────────────────────────────────────
ADMIN_PASSWORD=choose-a-strong-password

# ───────────────────────────────────────────────
# Daily cron auth (optional). When set, Vercel Cron must send
# `Authorization: Bearer <CRON_SECRET>`. Vercel injects this automatically.
# ───────────────────────────────────────────────
CRON_SECRET=optional-random-secret
